{
  "ApiUrl": "https://localhost:5001/api",
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=LMS;Trusted_Connection=True;MultipleActiveResultSets=true"
  },
  "Jwt": {
    "Key": "YourSuperSecretKeyHere",
    "Issuer": "YourIssuer",
    "Audience": "YourAudience",
    "TokenLifetime": "00:30:00"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "UseConditionalLogger": true,
  "LoggerProviders": {
    "Development": "ConsoleLoggerProvider",
    "Production": "FileLoggerProvider",
    "Default": "ConsoleLoggerProvider"
  },
  "AllowedHosts": "*"
}
