<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net8.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<PackageId>Zentient.Extensions</PackageId>
		<AssemblyTitle>Zentient Framework Repository API</AssemblyTitle>
		<AssemblyProduct>Zentient.Extensions</AssemblyProduct>
		<Version>1.0.0-beta</Version>
		<Authors>Ulf Bourelius</Authors>
		<Description>Zentient.Extensions is a part of the Zentient Framework that provides a collection of useful extension methods for various types in C#.</Description>
		<PackageTags>ZentientFramework;Extensions;C#</PackageTags>
		<PackageLicenseExpression>MIT</PackageLicenseExpression>
		<PackageLicenseFile></PackageLicenseFile>
		<PackageProjectUrl>https://github.com/ulfbou/ZentientFramework/wiki</PackageProjectUrl>
		<RepositoryUrl>https://github.com/ulfbou/ZentientFramework</RepositoryUrl>
		<RepositoryType>git</RepositoryType>
		<LangVersion>latest</LangVersion>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="Microsoft.EntityFrameworkCore" Version="8.0.6" />
	</ItemGroup>

</Project>
